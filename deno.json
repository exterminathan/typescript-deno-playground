{
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite",
    "process": "deno run --allow-write --allow-net ./src/dataProcessor.ts",
    "build": "deno run -A --node-modules-dir npm:vite build",
    "preview": "deno run -A --node-modules-dir npm:vite preview",
    "serve": "deno run --allow-net --allow-read https://deno.land/std@0.157.0/http/file_server.ts dist/",
    "hook": "deno run --allow-read --allow-run --allow-write https://deno.land/x/deno_hooks@0.1.2/mod.ts"
  },
  "compilerOptions": {
    "lib": [
      "es2015",
      "dom",
      "dom.iterable",
      "esnext",
      "deno.ns"
    ],
    "types": [
      "npm:@types/leaflet"
    ]
  },
  "imports": {
    "leaflet": "npm:leaflet@^1.9.4",
    "leaflet-control-geocoder": "npm:leaflet-control-geocoder@^2.4.0"
  }
}
